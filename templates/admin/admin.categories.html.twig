{% extends "baseadmin.html.twig" %}
{% block body %}
    <table class="table table-striped" aria-label="">
        <tbody>
            {% for categorie in categories %}
                <tr class="align-middle" scope="col">
                    <td class="text-left" scope="col">
                        {{ categorie.name }}<br>
                    </td>
                    <td>
                        <a href="{{ path('admin.categorie.suppr', {id:categorie.id}) }}" class="btn btn-danger" onclick="return confirm('Etes-vous sûr de vouloir supprimer {{ categorie.name }} ?')">Supprimer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {{ form_start(formcategorie) }}
    {{ form_end(formcategorie) }}
{% endblock %}